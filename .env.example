# Project
PROJECT_NAME=nyc-taxi-data-platform
ENVIRONMENT=local
LOG_LEVEL=INFO
METRICS_OUTPUT_PATH=metrics/pipeline_metrics.jsonl

# Dataset selection. Production defaults must satisfy the project threshold.
DATASET_START_MONTH=2023-01
DATASET_END_MONTH=2023-12
SAMPLE_MODE=false
MIN_DATASET_RECORDS=20000000
MIN_RAW_SIZE_GB=10
MIN_DATASET_RAW_BYTES=10737418240

# NYC TLC sources
NYC_TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data
TAXI_ZONE_LOOKUP_URL=https://d37ci6vzurychx.cloudfront.net/misc/taxi_zone_lookup.csv

# MinIO / S3A
MINIO_IMAGE_TAG=RELEASE.2025-04-22T22-12-26Z
MINIO_MC_IMAGE_TAG=RELEASE.2025-04-16T18-13-26Z
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=nyc-taxi
S3_WAREHOUSE_PATH=s3a://nyc-taxi
BRONZE_DELTA_PATH=s3a://nyc-taxi/bronze/yellow_taxi_trips
SILVER_DELTA_PATH=s3a://nyc-taxi/silver/yellow_taxi_trips
QUARANTINE_DELTA_PATH=s3a://nyc-taxi/quarantine/yellow_taxi_trips
INGESTION_MANIFEST_PATH=manifests/bronze_ingestion_manifest.jsonl

# Spark
SPARK_IMAGE_TAG=3.5.1
SPARK_MASTER_HOST=spark-master
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_MASTER_PORT=7077
SPARK_MASTER_UI_PORT=18080
SPARK_WORKER_UI_PORT=18081
SPARK_WORKER_MEMORY=2g
SPARK_WORKER_CORES=2
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=2g
SPARK_EXECUTOR_CORES=2

# ClickHouse
CLICKHOUSE_IMAGE_TAG=24.8
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_NATIVE_HOST_PORT=9009
CLICKHOUSE_DATABASE=nyc_taxi
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Airflow
AIRFLOW_IMAGE_TAG=3.1.0
AIRFLOW_UID=50000
AIRFLOW_WEBSERVER_PORT=8080
AIRFLOW_WEBSERVER_SECRET_KEY=change-me-for-local-only
AIRFLOW_API_JWT_SECRET=change-me-for-local-only
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_PIP_ADDITIONAL_REQUIREMENTS=apache-airflow-providers-docker>=4.4.0 pydantic>=2.7 PyYAML>=6.0 requests>=2.32 delta-spark>=3.2,<4.0 pyarrow>=15.0 pyspark>=3.5,<3.6
DBT_IMAGE=dnquocdat/nyc-taxi-dbt:latest
POSTGRES_IMAGE_TAG=16
AIRFLOW_POSTGRES_PORT=5433
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow
AIRFLOW_POSTGRES_DB=airflow

# Superset
SUPERSET_IMAGE_TAG=4.1.2
SUPERSET_PORT=8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com
SUPERSET_SECRET_KEY=change-me-for-local-only
